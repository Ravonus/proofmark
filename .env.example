# ── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://web3sign:web3sign_dev@127.0.0.1:5436/web3sign"

# ── Email (optional — leave blank to disable email features) ─
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@proofmark.local"
ADMIN_EMAIL=""

# ── Instance owner (optional) ───────────────────────────────
OWNER_ADDRESS=""
OWNER_CHAIN="ETH"

# ── Security (optional — enables vault/encryption features) ─
# Generate with: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=""

# ── Auth callbacks ──────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3100"
# Better Auth falls back to NEXTAUTH_URL when BETTER_AUTH_URL is blank.
BETTER_AUTH_URL=""
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=""

# ── Deployment ──────────────────────────────────────────────
# OSS defaults to 10 MB. Premium startup defaults to 100 MB unless overridden.
PROOFMARK_DEPLOYMENT_MODE="oss"
PDF_UPLOAD_MAX_MB="10"

# ── Chain RPCs / token gate verification (optional) ─────────
# ETH token gating uses ETH_RPC_URL / EVM_RPC_URL first, then falls back to PublicNode's public Ethereum RPC.
# SOL token gating uses SOL_RPC_URL / NEXT_PUBLIC_SOL_RPC_URL first, then falls back to Solana's public mainnet endpoint.
# BTC ordinal / rune gating uses ORD_RPC_URL when available, with an ordinals.com scraper as the public fallback.
# For rune balances from ORD_RPC_URL, run ord with --index-addresses and --index-runes.
# ETH_RPC_URL=""
# EVM_RPC_URL=""
# ETH_API_URL=""
# PUBLIC_ETH_RPC_URL=""
# SOL_RPC_URL=""
# NEXT_PUBLIC_SOL_RPC_URL=""
# SOL_API_URL=""
# PUBLIC_SOL_RPC_URL=""
# ORD_RPC_URL="http://localhost:8080"
# ORDINALS_BASE_URL="https://ordinals.com"

# ── Automation (optional) ───────────────────────────────────
AUTOMATION_SECRET=""

# ── AI (premium; auto-detected when present) ────────────────
# The app supports both the Proofmark-prefixed names below and common
# provider-standard names like OPENAI_API_KEY / ANTHROPIC_API_KEY.
# AI_OPENAI_API_KEY=""
# AI_ANTHROPIC_API_KEY=""
# AI_GOOGLE_API_KEY=""
# AI_OPENROUTER_API_KEY=""
# AI_LITELLM_API_KEY=""
# AI_LITELLM_BASE_URL="http://localhost:4000/v1"
# PROOFMARK_CONNECTOR_URL="http://127.0.0.1:3100"
# PROOFMARK_CONNECTOR_TOKEN=""
# PROOFMARK_CONNECTOR_LABEL="Local Connector"
# PROOFMARK_AI_CONNECTOR_TIMEOUT_MS="300000"
# PROOFMARK_CONNECTOR_FETCH_RETRIES="5"
# PROOFMARK_CONNECTOR_FETCH_BACKOFF_MS="1000"
# PROOFMARK_CODEX_ALLOW_MODEL_HINT="0"

# ── OAuth SSO (optional — BYO keys) ────────────────────────
# AUTH_GOOGLE_CLIENT_ID=""
# AUTH_GOOGLE_CLIENT_SECRET=""
# AUTH_GITHUB_CLIENT_ID=""
# AUTH_GITHUB_CLIENT_SECRET=""
# AUTH_DISCORD_CLIENT_ID=""
# AUTH_DISCORD_CLIENT_SECRET=""
# AUTH_X_CLIENT_ID=""
# AUTH_X_CLIENT_SECRET=""
# AUTH_MICROSOFT_CLIENT_ID=""
# AUTH_MICROSOFT_CLIENT_SECRET=""
# AUTH_OKTA_CLIENT_ID=""
# AUTH_OKTA_CLIENT_SECRET=""
# AUTH_OKTA_ISSUER=""
