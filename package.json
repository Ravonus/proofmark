{
  "name": "proofmark",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "cleanup": "(lsof -ti:3100 -ti:9090 | xargs kill -9 2>/dev/null; pkill -9 -f proofmark-engine 2>/dev/null; pkill -9 -f 'ws-entry' 2>/dev/null; rm -f rust-service/data/index/LOCK 2>/dev/null; true)",
    "dev": "npm run cleanup && npm run db:up && concurrently --kill-others \"PDF_UPLOAD_MAX_MB=${PDF_UPLOAD_MAX_MB:-10} npm run engine\" \"PROOFMARK_PREMIUM=0 PROOFMARK_DEPLOYMENT_MODE=${PROOFMARK_DEPLOYMENT_MODE:-oss} PDF_UPLOAD_MAX_MB=${PDF_UPLOAD_MAX_MB:-10} next dev --port 3100\"",
    "paid": "npm run cleanup && npm run db:up && concurrently --kill-others \"PDF_UPLOAD_MAX_MB=${PDF_UPLOAD_MAX_MB:-100} npm run engine\" \"PROOFMARK_DEPLOYMENT_MODE=${PROOFMARK_DEPLOYMENT_MODE:-premium} PDF_UPLOAD_MAX_MB=${PDF_UPLOAD_MAX_MB:-100} next dev --port 3100\" \"tsx premium/collaboration/ws-entry.ts\"",
    "db:up": "docker compose up db -d --wait 2>/dev/null || docker-compose up db -d 2>/dev/null || echo 'Docker not available — ensure Postgres is running on port 5436'",
    "collab:ws": "tsx premium/collaboration/ws-entry.ts",
    "connector:local": "tsx --env-file=.env scripts/run-local-connector.ts",
    "engine": "cd rust-service && cargo run --release",
    "engine:build": "cd rust-service && cargo build --release",
    "forensic:wasm": "mkdir -p src/lib/forensic/generated && cargo build --release --target wasm32-unknown-unknown --features wasm --manifest-path rust-service/crates/forensic-core/Cargo.toml && wasm-bindgen rust-service/crates/forensic-core/target/wasm32-unknown-unknown/release/forensic_core.wasm --out-dir src/lib/forensic/generated --target web",
    "build": "rm -rf .next && next build && node scripts/wait-for-next-traces.mjs",
    "start": "next start --port 3100",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "bench:pdf-analysis": "tsx scripts/benchmark-pdf-analysis.ts",
    "forensic:thresholds": "tsx scripts/evaluate-forensic-thresholds.ts",
    "seed:automation-contract": "tsx --env-file=.env scripts/create-automation-review-contract.ts",
    "seed:eye-tracking-test": "tsx --env-file=.env scripts/create-eye-tracking-test-contract.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "validate": "npm run type-check && npm run lint && npm run format:check && npm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@mediapipe/face_mesh": "^0.4.1633559619",
    "@mediapipe/tasks-vision": "^0.10.34",
    "@noble/curves": "^1.8.0",
    "@omnisat/lasereyes": "^0.0.163",
    "@scure/btc-signer": "^1.4.0",
    "@solana/wallet-adapter-base": "^0.9.23",
    "@solana/wallet-adapter-phantom": "^0.9.24",
    "@solana/wallet-adapter-react": "^0.15.35",
    "@solana/wallet-standard-wallet-adapter-react": "^1.1.2",
    "@solana/web3.js": "^1.95.0",
    "@t3-oss/env-nextjs": "^0.11.1",
    "@tanstack/react-query": "^5.62.0",
    "@tensorflow-models/face-landmarks-detection": "^1.0.5",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "@tensorflow/tfjs-converter": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "@trpc/client": "^11.0.0",
    "@trpc/next": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@types/ws": "^8.18.1",
    "@wagmi/connectors": "^5.7.0",
    "@wagmi/core": "^3.4.1",
    "better-auth": "1.2.7",
    "bs58": "^6.0.0",
    "drizzle-orm": "^0.38.0",
    "ethers": "^6.16.0",
    "framer-motion": "^12.38.0",
    "lib0": "^0.2.117",
    "lucide-react": "^1.7.0",
    "multiformats": "^13.4.2",
    "next": "^15.1.0",
    "nodemailer": "^6.9.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "superjson": "^2.2.2",
    "tweetnacl": "^1.0.3",
    "viem": "^2.21.0",
    "wagmi": "^2.14.0",
    "webgazer": "^3.5.3",
    "ws": "^8.20.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zod": "^3.24.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^6.4.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.14",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "null-loader": "^4.0.1",
    "postcss": "^8.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "optionalDependencies": {
    "geoip-lite": "^1.4.10"
  }
}
